{
  "name": "trenchclaw",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.9",
  "type": "module",
  "scripts": {
    "launch": "bun run --cwd .. launch",
    "assets:sync": "bun run ./scripts/sync-public-assets.ts",
    "dev": "bun run assets:sync && vite dev",
    "build": "bun run assets:sync && vite build",
    "preview": "bun run assets:sync && vite preview",
    "lint": "oxlint .",
    "test": "bun test ../tests/website",
    "svelte:check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "ci": "bun run lint && bun run typecheck && bun run build"
  },
  "dependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.53.4",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "marked": "^17.0.4",
    "svelte": "^5.53.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "oxlint": "^1.51.0",
    "svelte-check": "^4.4.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
