# Human/operator-editable settings.
# This file is loaded by systemd first.

TRENCHCLAW_PROFILE=default
TRENCHCLAW_SETTINGS_USER_FILE=/etc/trenchclaw/settings.user.yaml

# RPC endpoints
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=
HELIUS_WS_URL=wss://mainnet.helius-rpc.com/?api-key=
QUICKNODE_RPC_URL=https://
QUICKNODE_WS_URL=wss://
RPC_URL=https://api.mainnet-beta.solana.com
WS_URL=wss://api.mainnet-beta.solana.com

# Optional external APIs
HELIUS_API_KEY=
QUICKNODE_API_KEY=
ULTRA_API_KEY=
