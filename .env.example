HELIUS_API_KEY=your_helius_api_key_here

QUICKNODE_API_KEY=your_quicknode_api_key_here

PRIVATE_KEY=your_base58_private_key_here

# AI provider config (provider-agnostic, OpenAI-compatible)
# Supported providers: openrouter | openai | openai-compatible
TRENCHCLAW_AI_PROVIDER=openrouter
TRENCHCLAW_AI_MODEL=stepfun-ai/step-3.5-mini:free

# OpenRouter (default)
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Optional. Defaults to https://openrouter.ai/api/v1 when provider=openrouter
TRENCHCLAW_AI_BASE_URL=

# OpenAI (only needed when provider=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Generic OpenAI-compatible endpoint (provider=openai-compatible)
# TRENCHCLAW_AI_API_KEY=your_provider_api_key_here
# TRENCHCLAW_AI_BASE_URL=https://your-provider.example.com/v1


# QUICK CONFIG

RPC_URL=https://
ULTRA_API_KEY=
PRIVATE_KEY=
