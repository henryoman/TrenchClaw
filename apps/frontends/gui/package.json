{
  "name": "@trenchclaw/web-gui",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bun run --cwd ../../../ dev:bootstrap",
    "dev:standalone": "bun --bun ../../../node_modules/vite/bin/vite.js --host 127.0.0.1 --port 4173",
    "dev:runtime": "VITE_TRENCHCLAW_RUNTIME_URL=http://127.0.0.1:4020 bun --bun ../../../node_modules/vite/bin/vite.js --host 127.0.0.1 --port 4173",
    "build": "bun --bun ../../../node_modules/vite/bin/vite.js build",
    "preview": "bun --bun ../../../node_modules/vite/bin/vite.js preview",
    "typecheck": "bun --bun svelte-check --tsconfig ./tsconfig.json",
    "lint": "oxlint -c ../../../.oxlintrc.json .",
    "lint:fix": "oxlint -c ../../../.oxlintrc.json --fix ."
  },
  "dependencies": {
    "@ai-sdk/svelte": "^4.0.142",
    "@trenchclaw/types": "workspace:*",
    "ai": "^6.0.142",
    "marked": "^17.0.5"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.3.0",
    "oxlint": "^1.58.0",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.2",
    "vite": "^8.0.0"
  }
}
