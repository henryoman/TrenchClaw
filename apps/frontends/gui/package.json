{
  "name": "@trenchclaw/web-gui",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bun run --cwd ../../../ dev:bootstrap",
    "dev:standalone": "bun --bun vite --host 127.0.0.1 --port 4173",
    "dev:runtime": "VITE_TRENCHCLAW_RUNTIME_URL=http://127.0.0.1:4020 bun --bun vite --host 127.0.0.1 --port 4173",
    "build": "bun --bun vite build",
    "preview": "bun --bun vite preview",
    "typecheck": "bun --bun svelte-check --tsconfig ./tsconfig.json",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix ."
  },
  "dependencies": {
    "@ai-sdk/svelte": "^4.0.116",
    "@openrouter/ai-sdk-provider": "^2.2.5",
    "@trenchclaw/types": "workspace:*",
    "ai": "^6.0.116",
    "marked": "^17.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/json-schema": "^7.0.15",
    "oxlint": "^1.52.0",
    "svelte": "^5.53.9",
    "svelte-check": "^4.4.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
