{
  "name": "@trenchclaw/cli",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run index.ts dev",
    "start": "bun run index.ts start",
    "headless": "bun run index.ts headless",
    "cli": "bun run index.ts cli",
    "build": "bun build index.ts --target bun --outdir dist",
    "typecheck": "bunx --bun tsc --noEmit -p tsconfig.json",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix ."
  },
  "dependencies": {
    "@ai-sdk/openai": "3.0.33",
    "@trenchclaw/core": "workspace:*",
    "@trenchclaw/types": "workspace:*",
    "ai": "6.0.99",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxlint": "^1.49.0",
    "typescript": "^5.9.2"
  }
}
