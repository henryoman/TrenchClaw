{
  "name": "@trenchclaw/runner",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "bun index.ts",
    "build": "bun build index.ts --target bun --outdir dist",
    "dev:deps:bootstrap": "sh ./scripts/bootstrap-dev-tools.sh",
    "deps:bootstrap": "bun run dev:deps:bootstrap",
    "typecheck": "bunx --bun tsc --noEmit -p tsconfig.json",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix ."
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "oxlint": "^1.56.0",
    "typescript": "^6.0.2"
  }
}
