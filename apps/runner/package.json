{
  "name": "@trenchclaw/runner",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "bun index.ts",
    "build": "bun build index.ts --target bun --outdir dist",
    "deps:bootstrap": "sh ./scripts/bootstrap-deps.sh",
    "typecheck": "bunx --bun tsc --noEmit -p tsconfig.json",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix ."
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "oxlint": "^1.55.0",
    "typescript": "^5.9.3"
  }
}
