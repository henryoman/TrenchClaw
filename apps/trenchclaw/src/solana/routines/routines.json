{
  "createWallets": {
    "routineName": "createWallets",
    "command": "createWallets [count=<number>] [walletPath=<group.wallet>] [walletLocator.group=<group>] [walletLocator.wallet=<wallet>] [walletLocator.startIndex=<number>] [storage.walletGroup=<group>] [storage.createGroupIfMissing=true|false] [storage.keypairGenerator=bun|solana-cli] [groups='[{\"name\":\"core\",\"wallets\":[{\"name\":\"maker\"}],\"children\":[{\"name\":\"snipers\",\"count\":2,\"startIndex\":1}]}]'] [renames='[{\"from\":\"core.maker\",\"to\":\"core.makerMain\"}]'] [includePrivateKey=true|false] [privateKeyEncoding=base64|hex|bytes] [output.filePrefix=<prefix>] [output.includeIndexInFileName=true|false]",
    "defaults": {
      "count": 1,
      "storage.walletGroup": "core-wallets",
      "output.filePrefix": "wallet",
      "output.includeIndexInFileName": true
    }
  },
  "actionSequence": {
    "routineName": "actionSequence",
    "command": "actionSequence steps='[{\"key\":\"step-1\",\"actionName\":\"ultraSwap\",\"input\":{...}},{\"key\":\"step-2\",\"dependsOn\":\"step-1\",\"actionName\":\"createWallets\",\"input\":{...}}]'",
    "defaults": {
      "steps": [
        {
          "actionName": "createWallets",
          "input": {
            "count": 1,
            "includePrivateKey": false,
            "privateKeyEncoding": "base64",
            "storage": {
              "walletGroup": "core-wallets",
              "createGroupIfMissing": true,
              "keypairGenerator": "bun"
            },
            "output": {
              "filePrefix": "wallet",
              "includeIndexInFileName": true
            }
          }
        }
      ]
    }
  }
}
