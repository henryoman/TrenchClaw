{
  "createWallets": {
    "routineName": "createWallets",
    "command": "createWallets [count=<number>] [walletName=<wallet>] [walletNames='[\"wallet001\",\"wallet002\"]'] [storage.walletGroup=<group>] [storage.createGroupIfMissing=true|false] [walletGroups='[{\"name\":\"core-wallets\",\"wallets\":[{\"name\":\"maker\"}]},{\"name\":\"snipers\",\"count\":2,\"startIndex\":5,\"filePrefix\":\"s\"}]'] [renames='[{\"walletGroup\":\"core-wallets\",\"fromWalletName\":\"maker\",\"toWalletName\":\"makerMain\"}]'] [output.filePrefix=<prefix>] [output.startIndex=<number>] [output.includeIndexInFileName=true|false]",
    "defaults": {
      "count": 1,
      "storage.walletGroup": "core-wallets",
      "output.filePrefix": "wallet",
      "output.startIndex": 1,
      "output.includeIndexInFileName": true
    }
  },
  "actionSequence": {
    "routineName": "actionSequence",
    "command": "actionSequence steps='[{\"key\":\"step-1\",\"actionName\":\"ultraSwap\",\"input\":{...}},{\"key\":\"step-2\",\"dependsOn\":\"step-1\",\"actionName\":\"createWallets\",\"input\":{...}}]'",
    "defaults": {
      "steps": [
        {
          "actionName": "createWallets",
          "input": {
            "count": 1,
            "storage": {
              "walletGroup": "core-wallets",
              "createGroupIfMissing": true
            },
            "output": {
              "filePrefix": "wallet",
              "startIndex": 1,
              "includeIndexInFileName": true
            }
          }
        }
      ]
    }
  }
}
