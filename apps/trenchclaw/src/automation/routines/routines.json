{
  "createWallets": {
    "routineName": "createWallets",
    "command": "createWallets [count=<number>] [walletName=<wallet>] [walletNames='[\"one\",\"two\"]'] [storage.walletGroup=<group>] [storage.createGroupIfMissing=true|false] [walletGroups='[{\"name\":\"core-wallets\",\"wallets\":[{\"name\":\"one\"}]},{\"name\":\"snipers\",\"count\":2}]'] [renames='[{\"walletGroup\":\"core-wallets\",\"fromWalletName\":\"one\",\"toWalletName\":\"main\"}]']",
    "defaults": {
      "count": 1,
      "storage.walletGroup": "core-wallets"
    }
  },
  "actionSequence": {
    "routineName": "actionSequence",
    "command": "actionSequence steps='[{\"key\":\"step-1\",\"actionName\":\"ultraSwap\",\"input\":{...}},{\"key\":\"step-2\",\"dependsOn\":\"step-1\",\"actionName\":\"createWallets\",\"input\":{...}}]'",
    "defaults": {
      "steps": [
        {
          "actionName": "createWallets",
          "input": {
            "count": 1,
            "storage": {
              "walletGroup": "core-wallets",
              "createGroupIfMissing": true
            }
          }
        }
      ]
    }
  },
  "walletInventoryScan": {
    "routineName": "walletInventoryScan",
    "command": "walletInventoryScan requestKey=<request-key> input='{\"instanceId\":\"<id>\",\"walletGroup\":\"core-wallets\",\"includeZeroBalances\":false}' [summaryDepth=summary|full]",
    "defaults": {
      "summaryDepth": "full",
      "input": {
        "includeZeroBalances": false
      }
    }
  }
}
