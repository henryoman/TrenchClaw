{
  "version": 1,
  "defaults": {
    "model": "none",
    "user": "write",
    "system": "write"
  },
  "rules": [
    {
      "path": ".",
      "model": "read"
    },
    {
      "path": ".runtime-state/db/events",
      "model": "read"
    },
    {
      "path": ".runtime-state/db/sessions",
      "model": "read"
    },
    {
      "path": ".runtime-state/db/system",
      "model": "read"
    },
    {
      "path": ".runtime-state/db/summary",
      "model": "read"
    },
    {
      "path": ".runtime-state/db/summaries",
      "model": "read"
    },
    {
      "path": ".runtime-state/db/memory",
      "model": "read"
    },
    {
      "path": ".runtime-state/instances",
      "model": "write"
    },
    {
      "path": ".runtime-state/runtime",
      "model": "none"
    },
    {
      "path": ".runtime-state/generated",
      "model": "read"
    }
  ]
}
