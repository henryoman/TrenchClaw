{
  "configVersion": 1,
  "profile": "safe",
  "network": {
    "allowedClusters": [
      "devnet",
      "testnet"
    ]
  },
  "wallet": {
    "defaults": {
      "keyEncoding": "base64",
      "createWalletCountLimit": 1,
      "exportFormat": "base58"
    },
    "dangerously": {
      "allowPrivateKeyAccess": false,
      "allowWalletSigning": false,
      "allowCreatingWallets": false,
      "allowDeletingWallets": false,
      "allowExportingWallets": false,
      "allowImportingWallets": false,
      "allowListingWallets": true,
      "allowShowingWallets": true,
      "allowUpdatingWallets": false
    }
  },
  "trading": {
    "enabled": false,
    "liveWalletUse": false,
    "requireUserConfirmationForDangerousActions": true,
    "preferences": {
      "defaultSwapProvider": "ultra",
      "defaultSwapMode": "ExactIn",
      "defaultAmountUnit": "ui",
      "scheduleActionName": "scheduleManagedUltraSwap",
      "quickBuyPresets": [],
      "customPresets": []
    }
  },
  "agent": {
    "enabled": true,
    "dangerously": {
      "allowFilesystemWrites": false,
      "allowNetworkAccess": true,
      "allowSystemAccess": false,
      "allowHardwareAccess": false,
      "allowDirectKeypairAccess": false
    },
    "internetAccess": {
      "trustedSitesOnly": true,
      "allowFullAccess": false,
      "trustedSites": [],
      "blockedSites": [],
      "allowedProtocols": [
        "https"
      ],
      "blockedProtocols": [
        "http",
        "ftp",
        "file"
      ],
      "allowedPorts": [
        443
      ],
      "blockedPorts": [
        22,
        25,
        2375,
        2376
      ]
    }
  }
}
