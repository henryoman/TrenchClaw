{
  "version": 1,
  "defaults": {
    "model": "none",
    "user": "write",
    "system": "write"
  },
  "rules": [
    {
      "path": ".",
      "model": "read"
    },
    {
      "path": ".runtime-state/instances",
      "model": "none",
      "user": "write",
      "system": "write"
    },
    {
      "path": ".runtime-state/instances/active-instance.json",
      "model": "read",
      "user": "write",
      "system": "write"
    },
    {
      "path": ".runtime-state/instances/<active-instance>",
      "model": "read",
      "user": "write",
      "system": "write"
    },
    {
      "path": ".runtime-state/instances/<active-instance>/keypairs",
      "model": "write",
      "user": "write",
      "system": "write"
    }
  ]
}
