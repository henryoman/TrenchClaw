{
  "name": "@trenchclaw/core",
  "version": "0.1.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "cleanup:runtime": "bun run src/lib/agent-scripts/clean-runtime-artifacts.ts",
    "context:refresh": "bun run src/lib/agent-scripts/refresh-workspace-context.ts",
    "knowledge:refresh": "bun run src/lib/agent-scripts/refresh-knowledge-manifest.ts",
    "generate": "bun run context:refresh && bun run knowledge:refresh",
    "refresh": "bun run typecheck && bun run lint && bun run context:refresh",
    "systemd:install": "bun run ../../scripts/systemd/install.ts",
    "devnet:airdrop": "bun run src/solana/actions/wallet-based/airdrop/devnetAirdrop.ts",
    "action:run": "bun run src/solana/actions/execute.ts",
    "runtime:start": "bun run src/runtime/start-runtime-server.ts",
    "routine:run": "bun run src/solana/routines/execute.ts",
    "typecheck": "bunx --bun tsc --noEmit -p tsconfig.json",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "bun test ../../tests",
    "build": "bun build src/index.ts --target bun --outdir dist",
    "wallet:vanity": "bun run src/solana/actions/wallet-based/create-wallets/create-vanity-wallet.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "oxlint": "^1.56.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@openrouter/ai-sdk-provider": "^2.3.1",
    "@solana/kit": "^6.3.1",
    "@solana/transactions": "^6.3.1",
    "ai": "^6.0.116",
    "bash-tool": "^1.3.15",
    "bunqueue": "^2.6.33",
    "helius-sdk": "^2.2.2",
    "just-bash": "^2.13.1",
    "privacycash": "^1.1.20",
    "zod": "^4.3.6"
  }
}
