{
  "name": "@trenchclaw/core",
  "version": "0.1.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "cleanup:runtime": "bun run src/tools/scripts/cleanRuntimeArtifacts.ts",
    "context:refresh": "bun run src/tools/scripts/refreshWorkspaceContext.ts",
    "knowledge:refresh": "bun run src/tools/scripts/refreshKnowledgeIndex.ts",
    "generate": "bun run context:refresh && bun run knowledge:refresh",
    "refresh": "bun run typecheck && bun run lint && bun run context:refresh",
    "systemd:install": "bun run ../../scripts/systemd/install.ts",
    "devnet:airdrop": "bun run src/tools/wallet/airdrop/devnetAirdrop.ts",
    "action:run": "bun run src/tools/execute.ts",
    "runtime:start": "bun run src/startRuntimeServer.ts",
    "routine:run": "bun run src/automation/routines/execute.ts",
    "typecheck": "bunx --bun tsc --noEmit -p tsconfig.json",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "bun test ../../tests",
    "build": "bun build src/index.ts --target bun --outdir dist",
    "wallet:vanity": "bun run src/tools/scripts/createVanityWallet.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "oxlint": "^1.57.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@solana/kit": "^6.5.0",
    "@solana/transactions": "^6.5.0",
    "ai": "^6.0.138",
    "bash-tool": "^1.3.15",
    "bunqueue": "^2.6.77",
    "fast-xml-parser": "^5.5.9",
    "helius-sdk": "^2.2.2",
    "just-bash": "^2.14.0",
    "privacycash": "^1.1.20",
    "zod": "^4.3.6"
  }
}
