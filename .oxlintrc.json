{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "node": true
  },
  "plugins": ["typescript", "import", "unicorn", "oxc"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "ignorePatterns": [
    "lib/client/**",
    "coverage/**",
    "dist/**",
    "**/dist/**",
    "build/**",
    "node_modules/**"
  ],
  "rules": {
    "no-console": "off",
    "unicorn/no-empty-file": "off"
  },
  "overrides": [
    {
      "files": [
        "src/ai/core/dispatcher.ts"
      ],
      "rules": {
        "no-await-in-loop": "off"
      }
    },
    {
      "files": [
        "src/solana/**/*.ts",
        "src/apps/cli/views/**/*.ts"
      ],
      "rules": {
        "unicorn/no-empty-file": "off"
      }
    }
  ]
}
