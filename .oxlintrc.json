{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "node": true
  },
  "plugins": ["typescript", "import", "unicorn", "oxc"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "ignorePatterns": [
    "lib/client/**",
    "coverage/**",
    "dist/**",
    "**/dist/**",
    "build/**",
    ".svelte-kit/**",
    "**/.svelte-kit/**",
    "node_modules/**"
  ],
  "rules": {
    "no-console": "off",
    "unicorn/no-empty-file": "off"
  },
  "overrides": [
    {
      "files": [
        "apps/trenchclaw/src/ai/core/dispatcher.ts"
      ],
      "rules": {
        "no-await-in-loop": "off"
      }
    },
    {
      "files": [
        "apps/trenchclaw/src/solana/**/*.ts",
        "apps/frontends/cli/views/**/*.ts"
      ],
      "rules": {
        "unicorn/no-empty-file": "off"
      }
    },
    {
      "files": [
        "apps/frontends/gui/**/*.ts",
        "apps/frontends/gui/**/*.js",
        "apps/frontends/gui/**/*.svelte"
      ],
      "env": {
        "browser": true
      }
    },
    {
      "files": [
        "website/**/*.ts",
        "website/**/*.js",
        "website/**/*.svelte"
      ],
      "env": {
        "browser": true
      },
      "rules": {
        "import/no-unassigned-import": "off"
      }
    }
  ]
}
