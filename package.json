{
  "name": "@trenchclaw/monorepo",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "apps/frontends/*",
    "website"
  ],
  "scripts": {
    "dev": "bun run scripts/dev-bootstrap.ts",
    "dev:bootstrap": "bun run scripts/dev-bootstrap.ts",
    "dev:gui-only": "bun run --bun --cwd apps/frontends/gui dev",
    "runtime:dev": "TURBO_TELEMETRY_DISABLED=1 bunx --bun turbo run dev --filter=@trenchclaw/cli",
    "tui:dev": "TURBO_TELEMETRY_DISABLED=1 bunx --bun turbo run dev --filter=@trenchclaw/cli",
    "gui:dev": "bun run --bun --cwd apps/frontends/gui dev",
    "dev:parallel": "TURBO_TELEMETRY_DISABLED=1 bunx --bun turbo run dev --parallel --filter=@trenchclaw/cli --filter=@trenchclaw/web-gui",
    "dev:all": "TURBO_TELEMETRY_DISABLED=1 bunx --bun turbo run dev --parallel",
    "web:dev": "TURBO_TELEMETRY_DISABLED=1 bunx --bun turbo run dev --filter=@trenchclaw/web-gui",
    "website:dev": "bun run --bun --cwd website dev",
    "website:lint": "bun run --bun --cwd website lint",
    "website:typecheck": "bun run --bun --cwd website typecheck",
    "website:build": "bun run --bun --cwd website build",
    "website:preview": "bun run --bun --cwd website preview",
    "website:ci": "bun run --bun --cwd website ci",
    "start": "TURBO_TELEMETRY_DISABLED=1 bunx --bun turbo run start --filter=@trenchclaw/cli",
    "headless": "TURBO_TELEMETRY_DISABLED=1 bunx --bun turbo run headless --filter=@trenchclaw/cli",
    "cli": "TURBO_TELEMETRY_DISABLED=1 bunx --bun turbo run cli --filter=@trenchclaw/cli",
    "build": "TURBO_TELEMETRY_DISABLED=1 bunx --bun turbo run build",
    "typecheck": "TURBO_TELEMETRY_DISABLED=1 bunx --bun turbo run typecheck",
    "lint": "TURBO_TELEMETRY_DISABLED=1 bunx --bun turbo run lint",
    "lint:fix": "TURBO_TELEMETRY_DISABLED=1 bunx --bun turbo run lint:fix",
    "test": "TURBO_TELEMETRY_DISABLED=1 bunx --bun turbo run test",
    "generate": "bun run --cwd apps/trenchclaw generate",
    "context:refresh": "TURBO_TELEMETRY_DISABLED=1 bunx --bun turbo run context:refresh --filter=@trenchclaw/core",
    "cleanup:runtime": "bun run --cwd apps/trenchclaw cleanup:runtime",
    "refresh": "TURBO_TELEMETRY_DISABLED=1 bunx --bun turbo run refresh --filter=@trenchclaw/core",
    "verify:generate": "bun run lint && bun run build && bun run typecheck && bun run test && bun run generate",
    "deps:dupes": "bun run scripts/check-dependency-duplicates.ts",
    "deps:root-install": "bun install && bun run deps:dupes",
    "systemd:install": "bun run --cwd apps/trenchclaw systemd:install",
    "ci": "bun run lint && bun run typecheck && bun run test && bun run build"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "overrides": {
    "@types/node": "25.3.0",
    "@noble/curves": "1.9.7",
    "@noble/hashes": "1.8.0",
    "ffjavascript": "0.3.1",
    "tslib": "2.8.1",
    "undici-types": "7.22.0"
  }
}
