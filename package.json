{
  "name": "trenchclaw",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/apps/cli/index.ts dev",
    "start": "bun run src/apps/cli/index.ts start",
    "headless": "bun run src/apps/cli/index.ts headless",
    "cli": "bun run src/apps/cli/index.ts cli",
    "knowledge:refresh": "bun run scripts/knowledge/refresh-manifest.ts",
    "context:refresh": "bun run scripts/context/refresh-workspace-context.ts",
    "refresh": "bun run typecheck && bun run lint && bun run build && bun run context:refresh",
    "systemd:install": "bun run scripts/systemd/install.ts",
    "typecheck": "bunx tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "lint:ci": "oxlint --deny correctness --deny suspicious --deny perf .",
    "check:schema-backend": "bunx tsc --noEmit --pretty false",
    "test": "bun test",
    "build": "bun build src/apps/cli/index.ts --target bun --outdir dist",
    "ci": "bun run lint && bun run typecheck && bun run check:schema-backend && bun run test && bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxlint": "^1.49.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.30",
    "@opentui/core": "^0.1.81",
    "@solana/kit": "^6.1.0",
    "ai": "^6.0.97",
    "privacycash": "^1.0.16",
    "zod": "^4.3.6"
  }
}
